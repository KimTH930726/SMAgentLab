# ============================================================
# Ops-Navigator 환경 변수 예시
# 실제 사용 시 .env 로 복사하여 값을 채우세요
# cp .env.example .env
#
# 나머지 설정값(임베딩 모델, Ollama 모델명, 검색 기본값,
# 검색 임계값, JWT 만료시간 등)은 backend/core/config.py에
# 코드 기본값으로 관리됩니다. Admin UI에서 런타임 변경 가능.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=opsdb
POSTGRES_USER=ops
POSTGRES_PASSWORD=ops1234
DATABASE_URL=postgresql://ops:ops1234@postgres:5432/opsdb

# ── LLM Provider ─────────────────────────────────────────────
# 초기 부팅 시 사용할 프로바이더 ("ollama" | "inhouse")
# 이후 Admin UI에서 런타임 전환 가능
LLM_PROVIDER=inhouse
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── InHouse DevX LLM (OAuth2 Client Credentials) ─────────────
# 시스템 단일 자격증명 — 모든 사용자가 공유
# base_url에 /api/v1/auth/token, /api/v1/agent/chat 경로 자동 부착
INHOUSE_LLM_BASE_URL=https://devx-gw.shinsegae-inc.com
INHOUSE_LLM_CLIENT_ID=
INHOUSE_LLM_CLIENT_SECRET=
# Agent ID/Code (Admin UI에서 런타임 변경 가능)
# INHOUSE_LLM_AGENT_ID=b6958377-73f2-4234-a49c-2aa878350a2e
# INHOUSE_LLM_AGENT_CODE=playground

# ── 시크릿 키 ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-secret-key-in-production
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=

# ── 초기 관리자 계정 ─────────────────────────────────────────
ADMIN_DEFAULT_PASSWORD=admin1234

# ── Frontend → Backend 통신 ───────────────────────────────────
BACKEND_URL=http://backend:8000

# ── 이미지 버전 태그 (운영/폐쇄망 배포용) ─────────────────────
# docker-compose.prod.yml이 이 값을 참조하여 이미지 태그를 결정.
# 빌드/배포 시 동일한 값으로 .env에 명시 후
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# 권장 형식: vMAJOR.MINOR (예: v2.16)
IMAGE_TAG=latest
