# 루트 빌드 컨텍스트 슬림화
# (실제 빌드는 backend/, frontend-react/ 하위에서 일어나므로
#  여기는 보조 안전장치)

# VCS / IDE
.git
.gitignore
.vscode
.idea
*.swp

# 환경/시크릿
.env
.env.*
!.env.example

# 빌드/캐시 산출물
**/__pycache__
**/*.pyc
**/node_modules
**/dist
**/build

# OS 메타
.DS_Store
Thumbs.db
desktop.ini

# 도커/배포 산출물 (이미지 안에 들어가면 안 됨)
*.tar
*.tar.gz
smagentlab-images-*.tar*
backups/

# 문서/메모 (이미지 안에서 불필요)
docs/
*.md
!CLAUDE.md
!frontend-react/README.md

# 레거시
frontend/

# Teams 헬퍼 빌드 산출물 (런타임에 별도 마운트로 제공)
scripts/dist/build/
